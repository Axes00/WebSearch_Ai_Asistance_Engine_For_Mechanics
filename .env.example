# ─────────────────────────────────────────────
# Technical Digital Library — environment example
# Copy this file to `.env.local` and fill in values.
# ─────────────────────────────────────────────

# Absolute path to the archive root.
# Windows: use a stable junction/symlink, Google Drive, or OneDrive synced folder
#   e.g. D:\TechnicalLibrary  (junction → USB or fixed local folder)
#   or   G:\My Drive\MechanicaArchive
#   or   C:\Users\<you>\OneDrive\TechnicalLibrary
# macOS/Linux: /Users/you/TechnicalLibrary or /mnt/library
ARCHIVE_ROOT=D:\TechnicalLibrary

# Hint stored on each item; consumed by the UI / admin. One of:
#   local | google_drive_synced | onedrive_synced | external_drive
ARCHIVE_SOURCE_TYPE=external_drive

# Prisma / SQLite (V1). Swap to postgresql://... later.
DATABASE_URL="file:./dev.db"

# Default UI locale when none is negotiated. One of: el | en
DEFAULT_LOCALE=el

# Optional: LibreOffice soffice path for .doc → PDF preview in the viewer.
# If unset, Windows checks Program Files paths; failing that, install from
# https://www.libreoffice.org/ and optionally set full path:
# LIBREOFFICE_PATH=C:\\Program Files\\LibreOffice\\program\\soffice.exe

# Skip auto-rebuild probe before dev/build (not recommended).
# SKIP_NATIVE_CHECK=1

# Customer access sessions. Generate a random value with at least 32 chars.
ACCESS_SESSION_SECRET=

# Cloudflare Turnstile CAPTCHA keys:
# https://dash.cloudflare.com/?to=/:account/turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Resend email delivery. Keep the API key only in `.env.local`.
# The from address must be verified in your Resend account.
RESEND_API_KEY=
RESEND_FROM_EMAIL="Mechanica <access@your-verified-domain.example>"

# Local administrator login. Store a SHA-256 hash of:
#   <password>:<ACCESS_SESSION_SECRET>
ADMIN_EMAIL=
ADMIN_PASSWORD_HASH=
