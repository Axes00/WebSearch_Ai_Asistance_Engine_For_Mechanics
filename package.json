    "clsx": "^2.1.1",
    "framer-motion": "^11.15.0",
    "mammoth": "^1.12.0",
    "next": "^15.1.4",
    "next-intl": "^3.26.3",
    "pdf-poppler": "^0.2.3",
    "pdfjs-dist": "^5.6.205",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sqlite-vec": "^0.1.9",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
