    "postinstall": "prisma generate && npm rebuild better-sqlite3",
    "rebuild:native": "npm rebuild better-sqlite3"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0",
    "@react-email/render": "^2.0.8",
    "@xenova/transformers": "^2.17.2",
