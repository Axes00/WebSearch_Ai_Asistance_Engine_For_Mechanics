{
  "name": "technical-digital-library",
  "version": "0.1.0",
  "private": true,
  "description": "Bilingual Technical Digital Library & Legislation AI Tool — V1",
  "scripts": {
    "predev": "node scripts/ensure-better-sqlite3.cjs",
    "prestart": "node scripts/ensure-better-sqlite3.cjs",
    "prebuild": "node scripts/ensure-better-sqlite3.cjs",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "index": "tsx scripts/index-archive.ts",
    "index:ai": "node scripts/ensure-better-sqlite3.cjs && tsx scripts/index-ai.ts",
    "archive:blueprint:fs": "tsx scripts/export-archive-filesystem-blueprint.ts",
    "archive:verify": "tsx scripts/verify-archive-blueprint.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
